;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Base Builder"
run/main_scene="uid://d1avhktmf10v3"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="uid://bvahbp14r0hi7"

[autoload]

GameEvents="*uid://e2v4essuuvv0"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Puzzle Builder"

[editor]

naming/scene_name_casing=1

[file_customization]

folder_colors={
"res://Assets/": "red",
"res://Resources/": "pink",
"res://Scenes/": "green",
"res://UI/": "teal"
}

